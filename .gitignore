# ====================================================================
# Java 考研/Full-stack 项目通用 .gitignore 配置
# ====================================================================

# 1. 忽略编译输出目录（给计算机运行的成品/半成品，绝对不要交）
build/
bin/
target/
out/
*.class

# 2. 忽略 IntelliJ IDEA 的本地工作区配置
.idea/
*.iml
*.ipr
*.iws

# 3. 忽略 Eclipse 的本地环境偏好设置
.settings/
.classpath
.project

# 4. 忽略操作系统临时文件
.DS_Store
Thumbs.db
